# Copy this file to .env and adjust values for the current environment.

APP_ENV=production
APP_NAME=Infrastructure Project Management System

# Use / when the app is installed at the domain root, e.g. https://example.com/
# Use /ipms.lgu when installed in a subfolder, e.g. https://example.com/ipms.lgu/
APP_BASE_PATH=/

DB_HOST=localhost
DB_NAME=your_cyberpanel_database
DB_USER=your_cyberpanel_database_user
DB_PASS=your_cyberpanel_database_password
DB_CHARSET=utf8mb4

# SSO — must match SSO_SECRET_IPMS in Main LGU's .env
SSO_SHARED_SECRET=

MAIL_FROM_EMAIL=ipms.systemlgu@gmail.com
MAIL_FROM_NAME=LGU IPMS System
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=ipms.systemlgu@gmail.com
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls

# CIMMS integration — receiver is in https://github.com/EXEQUIELKENT/LGU (lgu-portal/public/api/ipms-requests.php)
CIMM_API_ENABLED=0
CIMM_API_URL=https://cimm.infragovservices.com/lgu-portal/public/api/ipms-requests.php
CIMM_API_KEY=
CIMM_API_TIMEOUT=20
CIMM_SSL_VERIFY=1
