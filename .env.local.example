APP_ENV=local
APP_NAME=Infrastructure Project Management System
APP_BASE_PATH=/ipms.lgu

DB_HOST=localhost
DB_NAME=lgu_infrastructure
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

MAIL_FROM_EMAIL=ipms.systemlgu@gmail.com
MAIL_FROM_NAME=LGU IPMS System
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=ipms.systemlgu@gmail.com
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls

# CIMMS integration — set same CIMM_API_KEY as CIMM_IPMS_API_KEY on the LGU server
# Local XAMPP default key matches LGU ipms-requests.php dev fallback
CIMM_API_ENABLED=1
CIMM_API_URL=http://localhost/LGU/lgu-portal/public/api/ipms-requests.php
CIMM_API_KEY=CIMM_IPMS_SHARED_KEY_2026
CIMM_API_TIMEOUT=20
CIMM_SSL_VERIFY=0
